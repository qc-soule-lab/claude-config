{
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~:*)",
      "Read(/home/jovyan/.claude/.credentials.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "/home/jovyan/.claude/bin/check-memory-freshness.sh", "timeout": 15 },
          { "type": "command", "command": "/home/jovyan/.claude/bin/list-project-memory.sh", "timeout": 10 },
          { "type": "command", "command": "/home/jovyan/.claude/bin/check-memory-index-sync.sh", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          { "type": "command", "command": "/home/jovyan/.claude/bin/ethical-check-webfetch.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          { "type": "command", "command": "/home/jovyan/.claude/bin/check-no-secrets-precommit.sh", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          { "type": "command", "command": "/home/jovyan/.claude/bin/memory-reminder-after-commit.sh", "timeout": 5 }
        ]
      }
    ]
  }
}
