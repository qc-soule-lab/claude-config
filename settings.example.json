{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/check-memory-freshness.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$HOME/.claude/bin/list-project-memory.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$HOME/.claude/bin/check-memory-index-sync.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/ethical-check-webfetch.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/check-no-secrets-precommit.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$HOME/.claude/bin/pre-commit-gate.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/memory-reminder-after-commit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
